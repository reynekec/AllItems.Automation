<UserControl x:Class="AllItems.Automation.Browser.App.Views.FlowCanvasView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:flow="clr-namespace:AllItems.Automation.Browser.App.Models.Flow"
             xmlns:views="clr-namespace:AllItems.Automation.Browser.App.Views"
             mc:Ignorable="d"
            MinWidth="420"
             MinHeight="320"
             Focusable="True"
             PreviewKeyDown="OnPreviewKeyDown">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <views:SelectionContainsNodeIdConverter x:Key="SelectionContainsNodeIdConverter" />

        <Style x:Key="CanvasToolbarGlyphStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Width" Value="16" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
            <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
            <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
        </Style>

        <Style x:Key="CanvasToolbarGlyphBadgeStyle" TargetType="Border">
            <Setter Property="Width" Value="24" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="CornerRadius" Value="5" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Background" Value="#FFF2F4F7" />
            <Setter Property="BorderBrush" Value="#FFE2E8F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <ControlTemplate x:Key="SegmentedToolbarButtonLeftTemplate" TargetType="Button">
            <Border x:Name="Chrome"
                    Background="{TemplateBinding Background}"
                    CornerRadius="6,0,0,6">
                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                  Margin="{TemplateBinding Padding}" />
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Chrome" Property="Background" Value="#FFEAF2FA" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="Chrome" Property="Background" Value="#FFDCE7F3" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.45" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <ControlTemplate x:Key="SegmentedToolbarButtonMiddleTemplate" TargetType="Button">
            <Border x:Name="Chrome"
                    Background="{TemplateBinding Background}"
                    CornerRadius="0">
                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                  Margin="{TemplateBinding Padding}" />
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Chrome" Property="Background" Value="#FFEAF2FA" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="Chrome" Property="Background" Value="#FFDCE7F3" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.45" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <ControlTemplate x:Key="SegmentedToolbarButtonRightTemplate" TargetType="Button">
            <Border x:Name="Chrome"
                    Background="{TemplateBinding Background}"
                    CornerRadius="0,6,6,0">
                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                  Margin="{TemplateBinding Padding}" />
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Chrome" Property="Background" Value="#FFEAF2FA" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="Chrome" Property="Background" Value="#FFDCE7F3" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.45" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style x:Key="SegmentedToolbarButtonBaseStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#FF35506B" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="MinWidth" Value="40" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="SegmentedToolbarButtonLeftStyle"
               TargetType="Button"
               BasedOn="{StaticResource SegmentedToolbarButtonBaseStyle}">
            <Setter Property="Template" Value="{StaticResource SegmentedToolbarButtonLeftTemplate}" />
        </Style>

        <Style x:Key="SegmentedToolbarButtonMiddleStyle"
               TargetType="Button"
               BasedOn="{StaticResource SegmentedToolbarButtonBaseStyle}">
            <Setter Property="Template" Value="{StaticResource SegmentedToolbarButtonMiddleTemplate}" />
        </Style>

        <Style x:Key="SegmentedToolbarButtonRightStyle"
               TargetType="Button"
               BasedOn="{StaticResource SegmentedToolbarButtonBaseStyle}">
            <Setter Property="Template" Value="{StaticResource SegmentedToolbarButtonRightTemplate}" />
        </Style>

        <DataTemplate DataType="{x:Type flow:FlowActionNodeModel}">
            <views:FlowActionNodeControl
                SelectedNodeIds="{Binding DataContext.InteractionState.SelectedNodeIds, RelativeSource={RelativeSource AncestorType=UserControl}}"
                SuccessfulNodeIds="{Binding DataContext.SuccessfulRunNodeIds, RelativeSource={RelativeSource AncestorType=UserControl}}"
                FailedNodeIds="{Binding DataContext.FailedRunNodeIds, RelativeSource={RelativeSource AncestorType=UserControl}}" />
        </DataTemplate>

        <DataTemplate DataType="{x:Type flow:FlowContainerNodeModel}">
            <views:FlowContainerNodeControl
                SelectedNodeIds="{Binding DataContext.InteractionState.SelectedNodeIds, RelativeSource={RelativeSource AncestorType=UserControl}}"
                HoveredLaneId="{Binding DataContext.InteractionState.HoveredLaneId, RelativeSource={RelativeSource AncestorType=UserControl}}"
                ToggleCollapseCommand="{Binding DataContext.ToggleCollapseCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                SuccessfulNodeIds="{Binding DataContext.SuccessfulRunNodeIds, RelativeSource={RelativeSource AncestorType=UserControl}}"
                FailedNodeIds="{Binding DataContext.FailedRunNodeIds, RelativeSource={RelativeSource AncestorType=UserControl}}" />
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#FFF8FBFF" Offset="0" />
                <GradientStop Color="#FFF4F7FB" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Margin="0,0,0,10" Background="#FFF2F6FA" BorderBrush="#FFE1E8F0" BorderThickness="1" CornerRadius="0">
            <ToolBarTray Background="Transparent" IsLocked="True">
                <ToolBar Background="Transparent" BorderThickness="0" Padding="6,4">
                    <Button Margin="0,0,6,0" Command="{Binding NewCommand}" ToolTip="New">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource CanvasToolbarGlyphStyle}" Text="&#xE8E5;" />
                        </StackPanel>
                    </Button>
                    <Button Margin="0,0,6,0"
                            Command="{Binding SaveCommand}"
                            ToolTip="Save"
                            Visibility="{Binding HasOpenedFile, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource CanvasToolbarGlyphStyle}" Text="&#xE74E;" />
                        </StackPanel>
                    </Button>
                    <Button Margin="0,0,6,0" Command="{Binding SaveAsCommand}" ToolTip="Save As">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource CanvasToolbarGlyphStyle}" Text="&#xE792;" />
                        </StackPanel>
                    </Button>
                    <Button Margin="0,0,10,0" Command="{Binding OpenCommand}" ToolTip="Open Project">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="16" Height="16" Stretch="Uniform">
                                <Grid Width="16" Height="16">
                                    <Path Data="M2.4,4.9 H6.1 L7.4,6.1 H13.6 V12.9 H2.4 Z"
                                          Stroke="#FF35506B"
                                          StrokeThickness="1.2"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round"
                                          Fill="Transparent" />
                                    <Path Data="M2.4,4.9 V3.3 H6 L7.1,4.3 H13.6 V6.1"
                                          Stroke="#FF35506B"
                                          StrokeThickness="1.2"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round"
                                          Fill="Transparent" />
                                </Grid>
                            </Viewbox>
                        </StackPanel>
                    </Button>
                    <Separator />
                    <Border Margin="8,0,0,0"
                            Background="#FFFFFFFF"
                            BorderBrush="#FFD4DFE7"
                            BorderThickness="1"
                            CornerRadius="6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="1" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="1" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="1" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0"
                                    Style="{StaticResource SegmentedToolbarButtonLeftStyle}"
                                    Command="{Binding ValidateForRunCommand}"
                                    ToolTip="Validate Runtime Map (Syntax check)">
                                <Viewbox Width="15" Height="15" Stretch="Uniform">
                                    <Grid Width="16" Height="16">
                                        <Path Data="M4,2.5 H9.6 L12.5,5.4 V13.5 H4 Z M9.4,2.5 V5.6 H12.5"
                                              Stroke="#FF35506B"
                                              StrokeThickness="1.2"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round"
                                              Fill="Transparent" />
                                        <Path Data="M5.7,8.2 L7.2,9.7 L10.4,6.4"
                                              Stroke="#FF1F6FEB"
                                              StrokeThickness="1.5"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round" />
                                        <Path Data="M5.6,11.2 H8.8"
                                              Stroke="#FF35506B"
                                              StrokeThickness="1.2"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round" />
                                    </Grid>
                                </Viewbox>
                            </Button>

                            <Border Grid.Column="1"
                                    Background="#FFD4DFE7"
                                    Margin="0,6" />

                            <Button Grid.Column="2"
                                    Style="{StaticResource SegmentedToolbarButtonMiddleStyle}"
                                    Command="{Binding DataContext.StartCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    ToolTip="{Binding DataContext.RunButtonToolTip, RelativeSource={RelativeSource AncestorType=Window}}"
                                    Foreground="#FF1B6E3A">
                                <TextBlock Style="{StaticResource CanvasToolbarGlyphStyle}"
                                           Text="{Binding DataContext.RunButtonIconGlyph, RelativeSource={RelativeSource AncestorType=Window}}" />
                            </Button>

                            <Border Grid.Column="3"
                                    Background="#FFD4DFE7"
                                    Margin="0,6" />

                            <Button Grid.Column="4"
                                    Style="{StaticResource SegmentedToolbarButtonMiddleStyle}"
                                    Command="{Binding DataContext.DebugCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    ToolTip="Debug"
                                    Foreground="#FF8B5C12">
                                <TextBlock Style="{StaticResource CanvasToolbarGlyphStyle}" Text="&#xEBE8;" />
                            </Button>

                            <Border Grid.Column="5"
                                    Background="#FFD4DFE7"
                                    Margin="0,6" />

                            <Button Grid.Column="6"
                                    Style="{StaticResource SegmentedToolbarButtonRightStyle}"
                                    Command="{Binding DataContext.StopCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    ToolTip="Stop"
                                    Foreground="#FFB00020">
                                <TextBlock Style="{StaticResource CanvasToolbarGlyphStyle}" Text="&#xE71A;" />
                            </Button>
                        </Grid>
                    </Border>
                    <Separator />
                    <Button Margin="8,0,6,0" Command="{Binding CopySelectionCommand}" ToolTip="Copy (Ctrl+C)">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource CanvasToolbarGlyphStyle}" Text="&#xE8C8;" />
                        </StackPanel>
                    </Button>
                    <Button Margin="0,0,6,0" Command="{Binding PasteSelectionCommand}" ToolTip="Paste (Ctrl+V)">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource CanvasToolbarGlyphStyle}" Text="&#xE77F;" />
                        </StackPanel>
                    </Button>
                    <Button Margin="0,0,10,0" Command="{Binding DeleteSelectionCommand}" ToolTip="Delete (Del)">
                        <StackPanel Orientation="Horizontal">
                            <Border Style="{StaticResource CanvasToolbarGlyphBadgeStyle}"
                                    Margin="0"
                                    Background="#FFFDE8E7"
                                    BorderBrush="#FFF4C7C3">
                                <TextBlock Style="{StaticResource CanvasToolbarGlyphStyle}" Text="&#xE74D;" />
                            </Border>
                        </StackPanel>
                    </Button>
                    <Separator />
                    <Button Margin="8,0,6,0" Command="{Binding UndoCommand}" ToolTip="Undo (Ctrl+Z)">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource CanvasToolbarGlyphStyle}" Text="&#xE7A7;" />
                        </StackPanel>
                    </Button>
                    <Button Margin="0,0,10,0" Command="{Binding RedoCommand}" ToolTip="Redo (Ctrl+Y)">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource CanvasToolbarGlyphStyle}" Text="&#xE7A6;" />
                        </StackPanel>
                    </Button>
                    <Separator />
                    <Button Margin="8,0,0,0"
                            Command="{Binding AutoLayoutCommand}"
                            ToolTip="Auto Layout">
                        <StackPanel Orientation="Horizontal">
                            <Border Style="{StaticResource CanvasToolbarGlyphBadgeStyle}"
                                    Margin="0"
                                    Width="26"
                                    Height="26"
                                    Background="#FFDCEBFF"
                                    BorderBrush="#FF9AB8E8">
                                <Viewbox Width="16" Height="16" Stretch="Uniform">
                                    <Grid Width="16" Height="16">
                                        <Path Data="M8,5.1 V7.4 M4.2,9.2 H11.8"
                                              Stroke="#FF1F4786"
                                              StrokeThickness="1.5"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round" />
                                        <Path Data="M4.2,9.2 V10.2 M11.8,9.2 V10.2"
                                              Stroke="#FF1F4786"
                                              StrokeThickness="1.5"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round" />
                                        <Rectangle Width="3.6"
                                                   Height="3.6"
                                                   RadiusX="0.9"
                                                   RadiusY="0.9"
                                                   Fill="#FF2457A6"
                                                   Stroke="#FF173867"
                                                   StrokeThickness="0.9"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Top"
                                                   Margin="0,1.2,0,0" />
                                        <Rectangle Width="3.6"
                                                   Height="3.6"
                                                   RadiusX="0.9"
                                                   RadiusY="0.9"
                                                   Fill="#FF4F86DA"
                                                   Stroke="#FF173867"
                                                   StrokeThickness="0.9"
                                                   HorizontalAlignment="Left"
                                                   VerticalAlignment="Bottom"
                                                   Margin="1.9,0,0,1.5" />
                                        <Rectangle Width="3.6"
                                                   Height="3.6"
                                                   RadiusX="0.9"
                                                   RadiusY="0.9"
                                                   Fill="#FF4F86DA"
                                                   Stroke="#FF173867"
                                                   StrokeThickness="0.9"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Bottom"
                                                   Margin="0,0,1.9,1.5" />
                                    </Grid>
                                </Viewbox>
                            </Border>
                        </StackPanel>
                    </Button>
                </ToolBar>
            </ToolBarTray>
        </Border>

        <Border Grid.Row="1" BorderBrush="#FFD2DBE6" BorderThickness="1" CornerRadius="0" Background="#FFFFFFFF">
            <Canvas x:Name="FlowSurface"
                    Margin="4"
                    AllowDrop="True"
                    Background="#FFFFFFFF"
                    PreviewDrop="OnSurfaceDrop"
                    DragOver="OnSurfaceDragOver"
                    DragLeave="OnSurfaceDragLeave"
                    MouseMove="OnSurfaceMouseMove"
                    MouseLeftButtonDown="OnSurfaceMouseLeftButtonDown"
                    MouseLeftButtonUp="OnSurfaceMouseLeftButtonUp">

                <ItemsControl ItemsSource="{Binding Nodes}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Canvas.Left" Value="{Binding Bounds.X}" />
                            <Setter Property="Canvas.Top" Value="{Binding Bounds.Y}" />
                            <Setter Property="Width" Value="{Binding Bounds.Width}" />
                            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="OnNodeMouseLeftButtonDown" />
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                </ItemsControl>

                <ItemsControl ItemsSource="{Binding Nodes}" IsHitTestVisible="False" ClipToBounds="False">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Canvas.Left" Value="{Binding Bounds.X}" />
                            <Setter Property="Canvas.Top" Value="{Binding Bounds.Y}" />
                            <Setter Property="Height" Value="{Binding Bounds.Height}" />
                            <Setter Property="Panel.ZIndex" Value="20" />
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Height="{Binding Bounds.Height}">
                                <Border Width="18"
                                        Height="18"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        Margin="-30,0,0,0"
                                        CornerRadius="9"
                                        Background="#FF177E43"
                                        BorderBrush="#FFFFFFFF"
                                        BorderThickness="1.5"
                                        Visibility="Collapsed">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Value="True">
                                                    <DataTrigger.Binding>
                                                        <MultiBinding Converter="{StaticResource SelectionContainsNodeIdConverter}">
                                                            <Binding Path="NodeId" />
                                                            <Binding Path="DataContext.SuccessfulRunNodeIds" RelativeSource="{RelativeSource AncestorType=UserControl}" />
                                                        </MultiBinding>
                                                    </DataTrigger.Binding>
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock FontSize="12"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="White"
                                               Text="✔" />
                                </Border>

                                <Border Width="18"
                                        Height="18"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        Margin="-30,0,0,0"
                                        CornerRadius="9"
                                        Background="#FFC62828"
                                        BorderBrush="#FFFFFFFF"
                                        BorderThickness="1.5"
                                        Visibility="Collapsed">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Value="True">
                                                    <DataTrigger.Binding>
                                                        <MultiBinding Converter="{StaticResource SelectionContainsNodeIdConverter}">
                                                            <Binding Path="NodeId" />
                                                            <Binding Path="DataContext.FailedRunNodeIds" RelativeSource="{RelativeSource AncestorType=UserControl}" />
                                                        </MultiBinding>
                                                    </DataTrigger.Binding>
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock FontSize="12"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="White"
                                               Text="✖" />
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <ItemsControl ItemsSource="{Binding EdgeVisuals}" IsHitTestVisible="False">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type flow:FlowEdgeVisualModel}">
                            <Path Data="{Binding PathData}" Stroke="#FFA7B6C8" StrokeThickness="1.6" StrokeLineJoin="Round" SnapsToDevicePixels="True" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Rectangle x:Name="SelectionRectangle" Stroke="#FF3B82F6" StrokeDashArray="2,2" Fill="#223B82F6" Visibility="Collapsed" />
            </Canvas>
        </Border>
    </Grid>
</UserControl>
