<UserControl x:Class="AllItems.Automation.Browser.App.Views.NodeInspectors.Actions.ClickElementInspectorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="420"
             d:DesignWidth="320">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>

    <StackPanel>
        <TextBlock Text="Click element"
                   Style="{StaticResource NodeInspector.EmphasisValueTextStyle}"
                   Margin="0,0,0,8" />

        <Border Style="{StaticResource NodeInspector.CategoryContainerStyle}">
            <StackPanel>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource NodeInspector.CategoryHeaderTextStyle}" Text="{Binding CategoryName}" />
                        <TextBlock Style="{StaticResource NodeInspector.HelpTextStyle}" Text="{Binding HintText}" />
                    </StackPanel>

                    <Button Grid.Column="1"
                            Width="28"
                            Height="28"
                            Margin="8,0,0,0"
                            Padding="6"
                            VerticalAlignment="Top"
                            HorizontalAlignment="Right"
                            ToolTip="Open Browser Window"
                            Click="OpenBrowserWindow_Click"
                            Style="{StaticResource NodeInspector.SecondaryButtonStyle}">
                        <Viewbox Width="14" Height="14">
                            <Path Fill="#1F2937" Data="M 0,0 L 0,12 L 3.5,9 L 6,14 L 8,13 L 5.5,8 L 9,8 Z" />
                        </Viewbox>
                    </Button>
                </Grid>

                <StackPanel Margin="0,0,0,8">
                    <TextBlock Style="{StaticResource NodeInspector.RowLabelTextStyle}" Text="By" />
                    <ComboBox x:Name="SelectorModeComboBox"
                              ItemsSource="{Binding SelectorModes}"
                              SelectedItem="{Binding SelectedSelectorMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              SelectionChanged="SelectorModeComboBox_OnSelectionChanged"
                              Style="{StaticResource NodeInspector.ComboBoxStyle}" />
                </StackPanel>

                <StackPanel Margin="0,0,0,8">
                    <TextBlock Style="{StaticResource NodeInspector.RowLabelTextStyle}" Text="{Binding SelectorInputLabel}" />
                    <TextBox x:Name="SelectorValueTextBox"
                             Text="{Binding SelectorInputValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource NodeInspector.TextBoxStyle}" />
                    <TextBlock Style="{StaticResource NodeInspector.HelpTextStyle}"
                               Margin="0,4,0,0"
                               Text="{Binding SelectorInputHelpText}" />
                </StackPanel>

                <StackPanel Margin="0,0,0,8">
                    <TextBlock Style="{StaticResource NodeInspector.RowLabelTextStyle}" Text="Preview" />
                    <Border CornerRadius="4"
                            Padding="8"
                            Background="#FFFFFFFF"
                            BorderBrush="{StaticResource NodeInspector.BorderBrush}"
                            BorderThickness="1">
                        <TextBlock Style="{StaticResource NodeInspector.ValueTextStyle}"
                                   Text="{Binding SelectorPreview}"
                                   TextWrapping="Wrap" />
                    </Border>
                </StackPanel>

                <StackPanel Margin="0,0,0,8">
                    <TextBlock Style="{StaticResource NodeInspector.RowLabelTextStyle}" Text="Timeout Ms" />
                    <TextBox Text="{Binding TimeoutMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource NodeInspector.TextBoxStyle}" />
                </StackPanel>

                <Border Style="{StaticResource NodeInspector.ValidationBannerStyle}"
                        Visibility="{Binding HasUnsupportedOptions, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Foreground="{StaticResource NodeInspector.ValidationBrush}"
                                   Text="{Binding UnsupportedOptionsMessage}"
                                   TextWrapping="Wrap" />
                        <Button Margin="0,8,0,0"
                                HorizontalAlignment="Left"
                                Padding="10,4"
                                Command="{Binding ClearUnsupportedOptionsCommand}"
                                Content="Clear Unsupported Options"
                                Style="{StaticResource NodeInspector.SecondaryButtonStyle}" />
                    </StackPanel>
                </Border>

                <Button Margin="0,8,0,0"
                        HorizontalAlignment="Left"
                        Padding="10,4"
                        Command="{Binding ResetToDefaultsCommand}"
                        Content="Reset to Defaults"
                        Style="{StaticResource NodeInspector.SecondaryButtonStyle}" />

                <Border Style="{StaticResource NodeInspector.ValidationBannerStyle}"
                        Visibility="{Binding HasValidationErrors, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ItemsControl ItemsSource="{Binding ValidationErrors}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Foreground="{StaticResource NodeInspector.ValidationBrush}"
                                           Text="{Binding}"
                                           TextWrapping="Wrap" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
