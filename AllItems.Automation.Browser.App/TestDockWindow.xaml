<Window x:Class="AllItems.Automation.Browser.App.TestDockWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:docking="clr-namespace:AllItems.Automation.Browser.App.Docking.Controls"
        mc:Ignorable="d"
        Title="Docking Playground"
        Height="760"
        Width="1220"
        MinHeight="560"
        MinWidth="880"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        FontFamily="Segoe UI"
        Foreground="#FF1F2937"
        Background="#FFF3F4F6">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,8" LastChildFill="False">
            <TextBlock DockPanel.Dock="Left"
                       VerticalAlignment="Center"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="#FF1F2937"
                       Text="Dockable Panels Lab" />
            <Button DockPanel.Dock="Right"
                    Width="36"
                    Height="36"
                    Margin="12,0,0,0"
                    ToolTip="Settings"
                    Click="OnSettingsClick"
                    Background="#FFFFFFFF"
                    BorderBrush="#FFD0D7DE"
                    BorderThickness="1"
                    Padding="0">
                <Viewbox Width="18" Height="18" Stretch="Uniform">
                    <Path Fill="#FF1F2937"
                          Data="M8 0L9.2 1.8C9.6 1.9 10 2.1 10.4 2.3L12.5 1.7L14.1 4.3L12.6 5.9C12.7 6.3 12.8 6.7 12.8 7.1L14.6 8.3L13.3 10.9L11.1 10.7C10.8 11 10.4 11.3 10 11.5L9.7 13.7H6.9L6.6 11.5C6.2 11.3 5.8 11 5.5 10.7L3.3 10.9L2 8.3L3.8 7.1C3.8 6.7 3.9 6.3 4 5.9L2.5 4.3L4.1 1.7L6.2 2.3C6.6 2.1 7 1.9 7.4 1.8L8.6 0H8ZM8.3 4.3C6.7 4.3 5.4 5.6 5.4 7.2C5.4 8.8 6.7 10.1 8.3 10.1C9.9 10.1 11.2 8.8 11.2 7.2C11.2 5.6 9.9 4.3 8.3 4.3Z" />
                </Viewbox>
            </Button>
            <Button DockPanel.Dock="Right"
                    MinWidth="130"
                    Height="32"
                    Margin="12,0,0,0"
                    Background="#FFFFFFFF"
                    BorderBrush="#FFD0D7DE"
                    Foreground="#FF1F2937"
                    Command="{Binding ResetLayoutCommand}"
                    Content="Reset Layout" />
        </DockPanel>

        <docking:DockHost Grid.Row="1"
                          x:Name="DockHost"
                          PanelsSource="{Binding Panels}"
                          ActiveLayout="{Binding ActiveLayout, Mode=TwoWay}"
                          LayoutChangedCommand="{Binding LayoutChangedCommand}" />
    </Grid>
</Window>
