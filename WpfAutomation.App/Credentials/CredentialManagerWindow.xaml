<Window x:Class="WpfAutomation.App.Credentials.CredentialManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfAutomation.App.Credentials"
        mc:Ignorable="d"
        Title="Credential Manager"
        Height="700"
        Width="1060"
        MinHeight="620"
        MinWidth="980"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="True">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <local:WebAuthKindDisplayConverter x:Key="WebAuthKindDisplayConverter" />
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderBrush="#DDD" BorderThickness="1" Padding="10" CornerRadius="4">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,10,0,0">
                        <Button Content="+ New" Padding="10,4" Margin="0,0,8,0" Command="{Binding NewCommand}" />
                        <Button Content="Delete" Padding="10,4" Command="{Binding DeleteCommand}" />
                    </StackPanel>

                    <ListBox ItemsSource="{Binding Credentials}"
                             SelectedItem="{Binding SelectedCredential, Mode=TwoWay}"
                             DisplayMemberPath="DisplayName"
                             BorderThickness="0"
                             MouseDoubleClick="CredentialListBoxMouseDoubleClick" />
                </DockPanel>
            </Border>

            <Border Grid.Column="2" BorderBrush="#DDD" BorderThickness="1" Padding="12" CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Credential Details" FontWeight="SemiBold" FontSize="16" />

                            <StackPanel Margin="0,10,0,0" Visibility="{Binding HasSelection, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock Text="Credential name" Margin="0,0,0,4" />
                                <TextBox Text="{Binding SelectedCredential.Name, UpdateSourceTrigger=PropertyChanged}"
                                         AutomationProperties.Name="Credential name" />

                                <TextBlock Text="Authentication platform" Margin="0,12,0,4" />
                                <StackPanel Orientation="Horizontal">
                                    <RadioButton Content="Web" IsChecked="{Binding SelectedCredential.IsWebSelected}" Margin="0,0,12,0" AutomationProperties.Name="Authentication platform Web" />
                                    <RadioButton Content="Windows (coming soon)" IsChecked="{Binding SelectedCredential.IsWindowsSelected}" IsEnabled="False" AutomationProperties.Name="Authentication platform Windows coming soon" />
                                </StackPanel>

                                <TextBlock Text="Authentication" Margin="0,12,0,4" />
                                <ComboBox ItemsSource="{Binding SelectedCredential.WebAuthKinds}"
                                          SelectedItem="{Binding SelectedCredential.WebAuthKind, Mode=TwoWay}"
                                          AutomationProperties.Name="Authentication type">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Vertical">
                                                <TextBlock Text="{Binding ., Converter={StaticResource WebAuthKindDisplayConverter}}" FontWeight="Normal" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <TextBlock Text="{Binding SelectedCredential.WebAuthKindDescription}" 
                                           Margin="0,4,0,0" 
                                           Foreground="#666666" 
                                           FontSize="12" 
                                           TextWrapping="Wrap" />

                                <GroupBox Margin="0,10,0,0"
                                          Header="{Binding SelectedCredential.WebAuthKindDisplayName}">
                                    <StackPanel Margin="10,8,10,10">
                                        <StackPanel Margin="0,0,0,0"
                                                    Visibility="{Binding SelectedCredential.IsUsernamePasswordKind, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <TextBlock Text="Username" Margin="0,0,0,4" />
                                            <TextBox Text="{Binding SelectedCredential.Username, UpdateSourceTrigger=PropertyChanged}" AutomationProperties.Name="Username" />
                                            <TextBlock Text="Password" Margin="0,8,0,4" />
                                            <PasswordBox x:Name="UsernamePasswordValueBox" PasswordChanged="SecretPasswordChanged" Tag="Password" AutomationProperties.Name="Password" />
                                        </StackPanel>

                                        <StackPanel Margin="0,0,0,0"
                                                    Visibility="{Binding SelectedCredential.IsUsernameEmailOtpKind, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <TextBlock Text="Username" Margin="0,0,0,4" />
                                            <TextBox Text="{Binding SelectedCredential.Username, UpdateSourceTrigger=PropertyChanged}" AutomationProperties.Name="Email OTP username" />
                                            <TextBlock Text="Password" Margin="0,8,0,4" />
                                            <PasswordBox x:Name="EmailOtpPasswordBox" PasswordChanged="SecretPasswordChanged" Tag="Password" AutomationProperties.Name="Email OTP password" />

                                            <Expander Header="Email inbox (optional - if not set, you will be prompted for the code at runtime)"
                                                      IsExpanded="False"
                                                      Margin="0,10,0,0">
                                                <StackPanel Margin="0,8,0,0">
                                                    <TextBlock Text="IMAP host" Margin="0,0,0,4" />
                                                    <TextBox Text="{Binding SelectedCredential.ImapHost, UpdateSourceTrigger=PropertyChanged}" AutomationProperties.Name="IMAP host" />
                                                    <TextBlock Text="IMAP port" Margin="0,8,0,4" />
                                                    <TextBox Text="{Binding SelectedCredential.ImapPort, UpdateSourceTrigger=PropertyChanged}" AutomationProperties.Name="IMAP port" />
                                                    <TextBlock Text="IMAP username" Margin="0,8,0,4" />
                                                    <TextBox Text="{Binding SelectedCredential.ImapUsername, UpdateSourceTrigger=PropertyChanged}" AutomationProperties.Name="IMAP username" />
                                                    <TextBlock Text="IMAP password" Margin="0,8,0,4" />
                                                    <PasswordBox x:Name="ImapPasswordBox" PasswordChanged="SecretPasswordChanged" Tag="ImapPassword" AutomationProperties.Name="IMAP password" />
                                                    <TextBlock Text="Mailbox folder" Margin="0,8,0,4" />
                                                    <TextBox Text="{Binding SelectedCredential.MailboxFolder, UpdateSourceTrigger=PropertyChanged}" AutomationProperties.Name="Mailbox folder" />
                                                    <TextBlock Text="Subject contains" Margin="0,8,0,4" />
                                                    <TextBox Text="{Binding SelectedCredential.SubjectContains, UpdateSourceTrigger=PropertyChanged}" AutomationProperties.Name="Subject contains" />
                                                </StackPanel>
                                            </Expander>
                                        </StackPanel>

                                        <StackPanel Margin="0,0,0,0"
                                                    Visibility="{Binding SelectedCredential.IsUsernameSmsOtpKind, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <TextBlock Text="Username" Margin="0,0,0,4" />
                                            <TextBox Text="{Binding SelectedCredential.Username, UpdateSourceTrigger=PropertyChanged}" AutomationProperties.Name="SMS OTP username" />
                                            <TextBlock Text="Password" Margin="0,8,0,4" />
                                            <PasswordBox x:Name="SmsOtpPasswordBox" PasswordChanged="SecretPasswordChanged" Tag="Password" AutomationProperties.Name="SMS OTP password" />
                                            <TextBlock Text="Phone hint" Margin="0,8,0,4" />
                                            <TextBox Text="{Binding SelectedCredential.PhoneHint, UpdateSourceTrigger=PropertyChanged}" AutomationProperties.Name="Phone hint" />
                                        </StackPanel>

                                        <StackPanel Margin="0,0,0,0"
                                                    Visibility="{Binding SelectedCredential.IsTotpKind, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <TextBlock Text="Username" Margin="0,0,0,4" />
                                            <TextBox Text="{Binding SelectedCredential.Username, UpdateSourceTrigger=PropertyChanged}" AutomationProperties.Name="TOTP username" />
                                            <TextBlock Text="Password" Margin="0,8,0,4" />
                                            <PasswordBox x:Name="TotpPasswordBox" PasswordChanged="SecretPasswordChanged" Tag="Password" AutomationProperties.Name="TOTP password" />
                                            <TextBlock Text="TOTP secret (Base32)" Margin="0,8,0,4" />
                                            <PasswordBox x:Name="TotpSecretBox" PasswordChanged="SecretPasswordChanged" Tag="TotpSecret" AutomationProperties.Name="TOTP secret" />
                                        </StackPanel>

                                        <StackPanel Margin="0,0,0,0"
                                                    Visibility="{Binding SelectedCredential.IsOAuthSsoKind, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <TextBlock Text="Provider name" Margin="0,0,0,4" />
                                            <TextBox Text="{Binding SelectedCredential.ProviderName, UpdateSourceTrigger=PropertyChanged}" AutomationProperties.Name="Provider name" />
                                            <TextBlock Text="Username" Margin="0,8,0,4" />
                                            <TextBox Text="{Binding SelectedCredential.Username, UpdateSourceTrigger=PropertyChanged}" AutomationProperties.Name="OAuth SSO username" />
                                            <TextBlock Text="Password" Margin="0,8,0,4" />
                                            <PasswordBox x:Name="OAuthPasswordBox" PasswordChanged="SecretPasswordChanged" Tag="Password" AutomationProperties.Name="OAuth SSO password" />
                                        </StackPanel>

                                        <StackPanel Margin="0,0,0,0"
                                                    Visibility="{Binding SelectedCredential.IsHttpBasicAuthKind, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <TextBlock Text="Username" Margin="0,0,0,4" />
                                            <TextBox Text="{Binding SelectedCredential.Username, UpdateSourceTrigger=PropertyChanged}" AutomationProperties.Name="HTTP basic username" />
                                            <TextBlock Text="Password" Margin="0,8,0,4" />
                                            <PasswordBox x:Name="HttpBasicPasswordBox" PasswordChanged="SecretPasswordChanged" Tag="Password" AutomationProperties.Name="HTTP basic password" />
                                        </StackPanel>

                                        <StackPanel Margin="0,0,0,0"
                                                    Visibility="{Binding SelectedCredential.IsApiKeyBearerKind, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <TextBlock Text="Token name" Margin="0,0,0,4" />
                                            <TextBox Text="{Binding SelectedCredential.TokenName, UpdateSourceTrigger=PropertyChanged}" AutomationProperties.Name="Token name" />
                                            <TextBlock Text="Token" Margin="0,8,0,4" />
                                            <PasswordBox x:Name="ApiTokenBox" PasswordChanged="SecretPasswordChanged" Tag="Token" AutomationProperties.Name="Bearer token" />
                                        </StackPanel>

                                        <StackPanel Margin="0,0,0,0"
                                                    Visibility="{Binding SelectedCredential.IsCertificateMtlsKind, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <TextBlock Text="Certificate path" Margin="0,0,0,4" />
                                            <TextBox Text="{Binding SelectedCredential.CertificatePath, UpdateSourceTrigger=PropertyChanged}" AutomationProperties.Name="Certificate path" />
                                            <TextBlock Text="Certificate password" Margin="0,8,0,4" />
                                            <PasswordBox x:Name="CertificatePasswordBox" PasswordChanged="SecretPasswordChanged" Tag="CertificatePassword" AutomationProperties.Name="Certificate password" />
                                            <TextBlock Text="Private key path" Margin="0,8,0,4" />
                                            <TextBox Text="{Binding SelectedCredential.PrivateKeyPath, UpdateSourceTrigger=PropertyChanged}" AutomationProperties.Name="Private key path" />
                                        </StackPanel>

                                        <StackPanel Margin="0,0,0,0"
                                                    Visibility="{Binding SelectedCredential.IsCustomKind, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <TextBlock Text="Label" Margin="0,0,0,4" />
                                            <TextBox Text="{Binding SelectedCredential.Label, UpdateSourceTrigger=PropertyChanged}" AutomationProperties.Name="Custom label" />
                                            <TextBlock Text="Notes" Margin="0,8,0,4" />
                                            <TextBox Text="{Binding SelectedCredential.Notes, UpdateSourceTrigger=PropertyChanged}" Height="90" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" AutomationProperties.Name="Custom notes" />
                                        </StackPanel>
                                    </StackPanel>
                                </GroupBox>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>

                    <TextBlock Grid.Row="1"
                               Margin="0,12,0,0"
                               Foreground="#B00020"
                               Text="{Binding ValidationMessage}"
                               Visibility="{Binding HasValidationMessage, Converter={StaticResource BooleanToVisibilityConverter}}" />
                </Grid>
            </Border>
        </Grid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Use selected" MinWidth="110" Margin="0,0,8,0" Command="{Binding SelectCommand}" IsDefault="True" />
            <Button Content="Save changes" MinWidth="110" Margin="0,0,8,0" Command="{Binding SaveCommand}" />
            <Button Content="Cancel" MinWidth="110" Command="{Binding CancelCommand}" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
