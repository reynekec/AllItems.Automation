<Window x:Class="WpfAutomation.App.TestDockWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:docking="clr-namespace:WpfAutomation.App.Docking.Controls"
        mc:Ignorable="d"
        Title="Docking Playground"
        Height="760"
        Width="1220"
        MinHeight="560"
        MinWidth="880"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        FontFamily="Segoe UI"
        Foreground="#FF1F2937"
        Background="#FFF3F4F6">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,8" LastChildFill="False">
            <TextBlock DockPanel.Dock="Left"
                       VerticalAlignment="Center"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="#FF1F2937"
                       Text="Dockable Panels Lab" />
            <Button DockPanel.Dock="Right"
                    MinWidth="130"
                    Height="32"
                    Margin="12,0,0,0"
                    Background="#FFFFFFFF"
                    BorderBrush="#FFD0D7DE"
                    Foreground="#FF1F2937"
                    Command="{Binding ResetLayoutCommand}"
                    Content="Reset Layout" />
        </DockPanel>

        <docking:DockHost Grid.Row="1"
                          x:Name="DockHost"
                          PanelsSource="{Binding Panels}"
                          ActiveLayout="{Binding ActiveLayout, Mode=TwoWay}"
                          LayoutChangedCommand="{Binding LayoutChangedCommand}" />
    </Grid>
</Window>
