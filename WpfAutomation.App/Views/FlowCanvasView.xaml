<UserControl x:Class="WpfAutomation.App.Views.FlowCanvasView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:flow="clr-namespace:WpfAutomation.App.Models.Flow"
             xmlns:views="clr-namespace:WpfAutomation.App.Views"
             mc:Ignorable="d"
            MinWidth="420"
             MinHeight="320"
             Focusable="True"
             PreviewKeyDown="OnPreviewKeyDown">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <DataTemplate DataType="{x:Type flow:FlowActionNodeModel}">
            <views:FlowActionNodeControl
                SelectedNodeIds="{Binding DataContext.InteractionState.SelectedNodeIds, RelativeSource={RelativeSource AncestorType=UserControl}}" />
        </DataTemplate>

        <DataTemplate DataType="{x:Type flow:FlowContainerNodeModel}">
            <views:FlowContainerNodeControl
                SelectedNodeIds="{Binding DataContext.InteractionState.SelectedNodeIds, RelativeSource={RelativeSource AncestorType=UserControl}}"
                HoveredLaneId="{Binding DataContext.InteractionState.HoveredLaneId, RelativeSource={RelativeSource AncestorType=UserControl}}"
                ToggleCollapseCommand="{Binding DataContext.ToggleCollapseCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" />
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#FFF8FBFF" Offset="0" />
                <GradientStop Color="#FFF4F7FB" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Margin="0,0,0,10" Background="#FFF2F6FA" BorderBrush="#FFE1E8F0" BorderThickness="1" CornerRadius="0">
            <ToolBarTray Background="Transparent" IsLocked="True">
                <ToolBar Background="Transparent" BorderThickness="0" Padding="6,4">
                    <Button Content="Auto Layout" Margin="0,0,10,0" Command="{Binding AutoLayoutCommand}" />
                    <Separator />
                    <Button Content="Group" Margin="8,0,6,0" Command="{Binding AddGroupContainerCommand}" />
                    <Button Content="For" Margin="0,0,6,0" Command="{Binding AddForContainerCommand}" />
                    <Button Content="ForEach" Margin="0,0,6,0" Command="{Binding AddForEachContainerCommand}" />
                    <Button Content="While" Margin="0,0,6,0" Command="{Binding AddWhileContainerCommand}" />
                    <Button Content="Condition" Margin="0,0,10,0" Command="{Binding AddConditionContainerCommand}" />
                    <Separator />
                    <Button Content="Copy" Margin="8,0,6,0" Command="{Binding CopySelectionCommand}" />
                    <Button Content="Paste" Margin="0,0,6,0" Command="{Binding PasteSelectionCommand}" />
                    <Button Content="Delete" Margin="0,0,10,0" Command="{Binding DeleteSelectionCommand}" />
                    <Separator />
                    <Button Content="Undo" Margin="8,0,6,0" Command="{Binding UndoCommand}" />
                    <Button Content="Redo" Margin="0,0,10,0" Command="{Binding RedoCommand}" />
                    <Separator />
                        <Button Content="Save"
                            Margin="8,0,6,0"
                            Command="{Binding SaveCommand}"
                            Visibility="{Binding HasOpenedFile, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <Button Content="Save As" Margin="0,0,6,0" Command="{Binding SaveAsCommand}" />
                    <Button Content="Open" Margin="0,0,10,0" Command="{Binding OpenCommand}" />
                    <Separator />
                    <Button Content="Validate Runtime Map" Margin="8,0,0,0" Command="{Binding ValidateForRunCommand}" />
                </ToolBar>
            </ToolBarTray>
        </Border>

        <Border Grid.Row="1" BorderBrush="#FFD2DBE6" BorderThickness="1" CornerRadius="0" Background="#FFFFFFFF">
            <Canvas x:Name="FlowSurface"
                    Margin="4"
                    AllowDrop="True"
                    Background="#FFFFFFFF"
                    PreviewDrop="OnSurfaceDrop"
                    DragOver="OnSurfaceDragOver"
                    DragLeave="OnSurfaceDragLeave"
                    MouseMove="OnSurfaceMouseMove"
                    MouseLeftButtonDown="OnSurfaceMouseLeftButtonDown"
                    MouseLeftButtonUp="OnSurfaceMouseLeftButtonUp">

                <ItemsControl ItemsSource="{Binding Nodes}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Canvas.Left" Value="{Binding Bounds.X}" />
                            <Setter Property="Canvas.Top" Value="{Binding Bounds.Y}" />
                            <Setter Property="Width" Value="{Binding Bounds.Width}" />
                            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="OnNodeMouseLeftButtonDown" />
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                </ItemsControl>

                <ItemsControl ItemsSource="{Binding EdgeVisuals}" IsHitTestVisible="False">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type flow:FlowEdgeVisualModel}">
                            <Path Data="{Binding PathData}" Stroke="#FFA7B6C8" StrokeThickness="1.6" StrokeLineJoin="Round" SnapsToDevicePixels="True" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Rectangle x:Name="SelectionRectangle" Stroke="#FF3B82F6" StrokeDashArray="2,2" Fill="#223B82F6" Visibility="Collapsed" />
            </Canvas>
        </Border>
    </Grid>
</UserControl>
