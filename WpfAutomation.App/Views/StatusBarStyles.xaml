<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="StatusBar.BackgroundColor">#FF007ACC</Color>
    <Color x:Key="StatusBar.ForegroundColor">#FFFFFFFF</Color>
    <Color x:Key="StatusBar.ItemHoverColor">#3396D8FF</Color>
    <Color x:Key="StatusBar.ItemPressedColor">#4C96D8FF</Color>
    <Color x:Key="StatusBar.ItemDisabledForegroundColor">#B3FFFFFF</Color>
    <Color x:Key="StatusBar.FocusBorderColor">#FFF5F5F5</Color>

    <SolidColorBrush x:Key="StatusBar.BackgroundBrush" Color="{StaticResource StatusBar.BackgroundColor}" />
    <SolidColorBrush x:Key="StatusBar.ForegroundBrush" Color="{StaticResource StatusBar.ForegroundColor}" />
    <SolidColorBrush x:Key="StatusBar.ItemHoverBrush" Color="{StaticResource StatusBar.ItemHoverColor}" />
    <SolidColorBrush x:Key="StatusBar.ItemPressedBrush" Color="{StaticResource StatusBar.ItemPressedColor}" />
    <SolidColorBrush x:Key="StatusBar.ItemDisabledForegroundBrush" Color="{StaticResource StatusBar.ItemDisabledForegroundColor}" />
    <SolidColorBrush x:Key="StatusBar.FocusBorderBrush" Color="{StaticResource StatusBar.FocusBorderColor}" />

    <Style x:Key="StatusBarRootBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource StatusBar.BackgroundBrush}" />
        <Setter Property="MinHeight" Value="24" />
        <Setter Property="Padding" Value="4,0" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <Style x:Key="StatusBarStripPanelStyle" TargetType="StackPanel">
        <Setter Property="Orientation" Value="Horizontal" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="StatusBarItemButtonStyle" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource StatusBar.ForegroundBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="8,0" />
        <Setter Property="Height" Value="22" />
        <Setter Property="MinWidth" Value="28" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{StaticResource StatusBar.ItemHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{StaticResource StatusBar.ItemPressedBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{StaticResource StatusBar.ItemDisabledForegroundBrush}" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource StatusBar.FocusBorderBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="StatusBarItemIconStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,0,6,0" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontFamily" Value="Segoe UI Symbol" />
    </Style>

    <Style x:Key="StatusBarItemTextStyle" TargetType="TextBlock">
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>
</ResourceDictionary>