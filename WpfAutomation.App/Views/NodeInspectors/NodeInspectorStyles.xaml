<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Thickness x:Key="NodeInspector.Space.Xs">4</Thickness>
    <Thickness x:Key="NodeInspector.Space.Sm">8</Thickness>
    <Thickness x:Key="NodeInspector.Space.Md">12</Thickness>
    <Thickness x:Key="NodeInspector.Space.Lg">16</Thickness>

    <SolidColorBrush x:Key="NodeInspector.SurfaceBrush" Color="#FFF8FAFC" />
    <SolidColorBrush x:Key="NodeInspector.BorderBrush" Color="#FFD5DEE8" />
    <SolidColorBrush x:Key="NodeInspector.HeaderBrush" Color="#FF1F2937" />
    <SolidColorBrush x:Key="NodeInspector.BodyBrush" Color="#FF334155" />
    <SolidColorBrush x:Key="NodeInspector.EmphasisBrush" Color="#FF0F766E" />
    <SolidColorBrush x:Key="NodeInspector.HelpBrush" Color="#FF475569" />
    <SolidColorBrush x:Key="NodeInspector.ValidationBrush" Color="#FFB91C1C" />
    <SolidColorBrush x:Key="NodeInspector.ValidationSurfaceBrush" Color="#FFFEE2E2" />

    <Style x:Key="NodeInspector.CategoryContainerStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="12" />
        <Setter Property="Margin" Value="0,0,0,12" />
        <Setter Property="Background" Value="{StaticResource NodeInspector.SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource NodeInspector.BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="NodeInspector.CategoryHeaderTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource NodeInspector.HeaderBrush}" />
        <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <Style x:Key="NodeInspector.RowLabelTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource NodeInspector.BodyBrush}" />
        <Setter Property="Margin" Value="0,0,0,4" />
    </Style>

    <Style x:Key="NodeInspector.HelpTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{StaticResource NodeInspector.HelpBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <Style x:Key="NodeInspector.ValidationBannerStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource NodeInspector.ValidationSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource NodeInspector.ValidationBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="8" />
        <Setter Property="Margin" Value="0,10,0,0" />
    </Style>

    <Style x:Key="NodeInspector.ValueTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource NodeInspector.BodyBrush}" />
    </Style>

    <Style x:Key="NodeInspector.EmphasisValueTextStyle" TargetType="TextBlock" BasedOn="{StaticResource NodeInspector.ValueTextStyle}">
        <Setter Property="Foreground" Value="{StaticResource NodeInspector.EmphasisBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="NodeInspector.JsonEditorStyle" TargetType="TextBox">
        <Setter Property="FontFamily" Value="Consolas" />
        <Setter Property="MinHeight" Value="140" />
        <Setter Property="Padding" Value="8" />
        <Setter Property="AcceptsReturn" Value="True" />
        <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="HorizontalScrollBarVisibility" Value="Auto" />
        <Setter Property="BorderBrush" Value="{StaticResource NodeInspector.BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding HasValidationErrors}" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource NodeInspector.ValidationBrush}" />
                <Setter Property="BorderThickness" Value="2" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- ═══ TextBox Property Control Style ════════════════════════════════ -->
    <Style x:Key="NodeInspector.TextBoxStyle" TargetType="TextBox">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="Foreground" Value="{StaticResource NodeInspector.BodyBrush}" />
        <Setter Property="Background" Value="#FFFFFFFF" />
        <Setter Property="BorderBrush" Value="{StaticResource NodeInspector.BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="CaretBrush" Value="{StaticResource NodeInspector.BodyBrush}" />
        <Setter Property="SelectionBrush" Value="{StaticResource NodeInspector.EmphasisBrush}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource NodeInspector.EmphasisBrush}" />
            </Trigger>
            <Trigger Property="IsKeyboardFocused" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource NodeInspector.EmphasisBrush}" />
                <Setter Property="BorderThickness" Value="2" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="#FFB0B8C1" />
                <Setter Property="Background" Value="#FFF5F7FA" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ═══ ComboBox Property Control Style ═══════════════════════════════ -->
    <Style x:Key="NodeInspector.ComboBoxStyle" TargetType="ComboBox">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="Foreground" Value="{StaticResource NodeInspector.BodyBrush}" />
        <Setter Property="Background" Value="#FFFFFFFF" />
        <Setter Property="BorderBrush" Value="{StaticResource NodeInspector.BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource NodeInspector.EmphasisBrush}" />
            </Trigger>
            <Trigger Property="IsKeyboardFocused" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource NodeInspector.EmphasisBrush}" />
                <Setter Property="BorderThickness" Value="2" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="#FFB0B8C1" />
                <Setter Property="Background" Value="#FFF5F7FA" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="ComboBoxItem">
        <Setter Property="Foreground" Value="{StaticResource NodeInspector.BodyBrush}" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="Background"
                            Padding="{TemplateBinding Padding}"
                            Background="Transparent">
                        <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Background" Property="Background" Value="#FFE8F1ED" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Background" Property="Background" Value="#FFDAEDEA" />
                            <Setter Property="Foreground" Value="{StaticResource NodeInspector.EmphasisBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══ CheckBox Property Control Style ════════════════════════════════ -->
    <Style x:Key="NodeInspector.CheckBoxStyle" TargetType="CheckBox">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="Foreground" Value="{StaticResource NodeInspector.BodyBrush}" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border x:Name="CheckBox"
                                Grid.Column="0"
                                Width="18"
                                Height="18"
                                Margin="0,0,8,0"
                                Background="#FFFFFFFF"
                                BorderBrush="{StaticResource NodeInspector.BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="2"
                                VerticalAlignment="Center">
                            <TextBlock x:Name="CheckMark"
                                       Text="✓"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource NodeInspector.EmphasisBrush}"
                                       Visibility="Collapsed"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <ContentPresenter Grid.Column="1"
                                          VerticalAlignment="Center" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="CheckBox" Property="BorderBrush" Value="{StaticResource NodeInspector.EmphasisBrush}" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="CheckBox" Property="BorderBrush" Value="{StaticResource NodeInspector.EmphasisBrush}" />
                            <Setter TargetName="CheckBox" Property="BorderThickness" Value="2" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
                            <Setter TargetName="CheckBox" Property="Background" Value="#FFF0F9F6" />
                            <Setter TargetName="CheckBox" Property="BorderBrush" Value="{StaticResource NodeInspector.EmphasisBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="#FFB0B8C1" />
                            <Setter TargetName="CheckBox" Property="Background" Value="#FFF5F7FA" />
                            <Setter TargetName="CheckBox" Property="BorderBrush" Value="#FFDADFEA" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══ Button Property Control Style ════════════════════════════════ -->
    <Style x:Key="NodeInspector.ButtonStyle" TargetType="Button">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="#FFFFFFFF" />
        <Setter Property="Background" Value="{StaticResource NodeInspector.EmphasisBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource NodeInspector.EmphasisBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="MinWidth" Value="60" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="#FF1A6B60" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="#FF0E5550" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Border" Property="BorderBrush" Value="#FFFFFFFF" />
                            <Setter TargetName="Border" Property="BorderThickness" Value="2" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="#FFB0B8C1" />
                            <Setter TargetName="Border" Property="Background" Value="#FFD5DEE8" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══ Secondary Button Style ═══════════════════════════════════════ -->
    <Style x:Key="NodeInspector.SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource NodeInspector.ButtonStyle}">
        <Setter Property="Foreground" Value="{StaticResource NodeInspector.BodyBrush}" />
        <Setter Property="Background" Value="#FFF5F7FA" />
        <Setter Property="BorderBrush" Value="{StaticResource NodeInspector.BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsMouseOver}" Value="True">
                <Setter Property="Background" Value="#FFEEF4F1" />
            </DataTrigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>
