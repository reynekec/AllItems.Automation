<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══ Design tokens ═══════════════════════════════════════════════════ -->
    <SolidColorBrush x:Key="ActionsSidebar.BackgroundBrush"        Color="#FFFFFF" />
    <SolidColorBrush x:Key="ActionsSidebar.HeaderForegroundBrush"   Color="#1A1A1A" />
    <SolidColorBrush x:Key="ActionsSidebar.SearchBgBrush"           Color="#F5F5F5" />
    <SolidColorBrush x:Key="ActionsSidebar.SearchBorderBrush"       Color="#D1D1D1" />
    <SolidColorBrush x:Key="ActionsSidebar.SearchFocusBrush"        Color="#0078D4" />
    <SolidColorBrush x:Key="ActionsSidebar.SearchPlaceholderBrush"  Color="#9E9E9E" />
    <SolidColorBrush x:Key="ActionsSidebar.SearchIconBrush"         Color="#737373" />
    <SolidColorBrush x:Key="ActionsSidebarSearchPlaceholderBrush"   Color="#9E9E9E" />
    <SolidColorBrush x:Key="ActionsSidebarSearchIconBrush"          Color="#737373" />
    <SolidColorBrush x:Key="ActionsSidebar.AccentBrush"             Color="#0078D4" />
    <SolidColorBrush x:Key="ActionsSidebar.DividerBrush"            Color="#EBEBEB" />
    <SolidColorBrush x:Key="ActionsSidebar.CategoryTextBrush"       Color="#5D5D5D" />
    <SolidColorBrush x:Key="ActionsSidebar.TextBrush"               Color="#242424" />
    <SolidColorBrush x:Key="ActionsSidebar.ChevronBrush"            Color="#8A8A8A" />
    <SolidColorBrush x:Key="ActionsSidebar.ChevronExpandedBrush"    Color="#0078D4" />
    <SolidColorBrush x:Key="ActionsSidebar.RowHoverBrush"           Color="#F0F6FF" />
    <SolidColorBrush x:Key="ActionsSidebar.ItemHoverBrush"          Color="#EEF4FC" />
    <SolidColorBrush x:Key="ActionsSidebar.ItemPressBrush"          Color="#D9E9F8" />

    <!-- ═══ Root ══════════════════════════════════════════════════════════ -->
    <Style x:Key="ActionsSidebarRootBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource ActionsSidebar.BackgroundBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsEnabled, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="False">
                <Setter Property="Opacity" Value="0.62" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- ═══ Header ════════════════════════════════════════════════════════ -->
    <Style x:Key="ActionsSidebarHeaderTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource ActionsSidebar.HeaderForegroundBrush}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Margin" Value="12,10,12,8" />
    </Style>

    <!-- ═══ Search ════════════════════════════════════════════════════════ -->
    <Style x:Key="ActionsSidebarSearchContainerStyle" TargetType="Border">
        <Setter Property="Height" Value="28" />
        <Setter Property="Margin" Value="8,0,8,8" />
        <Setter Property="Background" Value="{StaticResource ActionsSidebar.SearchBgBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource ActionsSidebar.SearchBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="3" />
        <Setter Property="Padding" Value="4,0" />
        <Style.Triggers>
            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource ActionsSidebar.SearchFocusBrush}" />
                <Setter Property="Background" Value="#FFFFFF" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ActionsSidebarSearchBoxStyle" TargetType="TextBox">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{StaticResource ActionsSidebar.TextBrush}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Padding" Value="2,0,0,0" />
        <Setter Property="CaretBrush" Value="{StaticResource ActionsSidebar.AccentBrush}" />
        <Setter Property="SelectionBrush" Value="{StaticResource ActionsSidebar.AccentBrush}" />
    </Style>

    <!-- ═══ TreeView ══════════════════════════════════════════════════════ -->
    <Style x:Key="ActionsSidebarTreeViewStyle" TargetType="TreeView">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <!--
        TreeViewItem base style — holds the custom ControlTemplate.
        A derived style in UserControl.Resources adds EventSetters (cannot live
        in a standalone ResourceDictionary without x:Class).
    -->
    <Style x:Key="ActionsSidebarTreeViewItemBaseStyle" TargetType="TreeViewItem">
        <Setter Property="IsExpanded" Value="False" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TreeViewItem">
                    <StackPanel>

                        <!--
                            Header row.
                            BorderThickness / BorderBrush are transparent by default;
                            the IsExpanded trigger turns the left 3 px blue.
                        -->
                        <Border x:Name="Row"
                                Background="Transparent"
                                MinHeight="28"
                                BorderThickness="3,0,0,0"
                                BorderBrush="Transparent">
                            <DockPanel LastChildFill="True">

                                <!--
                                    22 px chevron column.
                                    The ToggleButton drives IsExpanded via two-way binding.
                                    Its template is invisible so the Path drawn on top of it
                                    stays in the outer ControlTemplate scope and can be
                                    targeted by triggers below.
                                -->
                                <Grid DockPanel.Dock="Left" Width="22" VerticalAlignment="Stretch">
                                    <ToggleButton x:Name="ExpanderToggle"
                                                  IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Focusable="False">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="Transparent" />
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                    <!-- Right-pointing chevron (collapsed state) -->
                                    <Path x:Name="ChevronRight"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Width="8" Height="8"
                                          Stretch="Uniform"
                                          Stroke="{StaticResource ActionsSidebar.ChevronBrush}"
                                          StrokeThickness="1.5"
                                          StrokeLineJoin="Round"
                                          Data="M 2,1 L 7,5 L 2,9" />
                                    <!-- Down-pointing chevron (expanded state) -->
                                    <Path x:Name="ChevronDown"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Width="8" Height="8"
                                          Stretch="Uniform"
                                          Stroke="{StaticResource ActionsSidebar.ChevronExpandedBrush}"
                                          StrokeThickness="1.5"
                                          StrokeLineJoin="Round"
                                          Data="M 1,3 L 5,7 L 9,3"
                                          Visibility="Collapsed" />
                                </Grid>

                                <!-- Item header content -->
                                <ContentPresenter x:Name="HeaderHost"
                                                  Margin="2,0,8,0"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Stretch"
                                                  ContentSource="Header" />
                            </DockPanel>
                        </Border>

                        <!-- Child items (collapsed by default) -->
                        <ItemsPresenter x:Name="ChildItemsHost" Visibility="Collapsed" />

                    </StackPanel>
                    <ControlTemplate.Triggers>

                        <!-- Leaf items (actions): hide chevron column -->
                        <Trigger Property="HasItems" Value="False">
                            <Setter TargetName="ExpanderToggle" Property="Visibility" Value="Hidden" />
                            <Setter TargetName="ChevronRight" Property="Visibility" Value="Hidden" />
                        </Trigger>

                        <!-- Category items: add top spacing to separate sections -->
                        <Trigger Property="HasItems" Value="True">
                            <Setter TargetName="Row" Property="Margin" Value="0,8,0,0" />
                        </Trigger>

                        <!-- Expanded: show children, blue left accent, swap to down chevron -->
                        <Trigger Property="IsExpanded" Value="True">
                            <Setter TargetName="ChildItemsHost" Property="Visibility" Value="Visible" />
                            <Setter TargetName="Row" Property="BorderBrush" Value="{StaticResource ActionsSidebar.AccentBrush}" />
                            <Setter TargetName="ChevronRight" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="ChevronDown" Property="Visibility" Value="Visible" />
                        </Trigger>

                        <!-- Category hover (only on rows that have children) -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True" />
                                <Condition Property="HasItems" Value="True" />
                            </MultiTrigger.Conditions>
                            <MultiTrigger.Setters>
                                <Setter TargetName="Row" Property="Background" Value="{StaticResource ActionsSidebar.RowHoverBrush}" />
                            </MultiTrigger.Setters>
                        </MultiTrigger>

                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══ Category header text ══════════════════════════════════════════ -->
    <Style x:Key="ActionsSidebarCategoryHeaderTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource ActionsSidebar.CategoryTextBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- ═══ Action button ═════════════════════════════════════════════════ -->
    <Style x:Key="ActionsSidebarActionButtonStyle" TargetType="Button">
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Padding" Value="8,0" />
        <Setter Property="Height" Value="26" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="Foreground" Value="{StaticResource ActionsSidebar.TextBrush}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg" Background="{TemplateBinding Background}" MinHeight="26">
                        <ContentPresenter Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource ActionsSidebar.ItemHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource ActionsSidebar.ItemPressBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bg" Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══ Empty state ═══════════════════════════════════════════════════ -->
    <Style x:Key="ActionsSidebarEmptyStateStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource ActionsSidebar.CategoryTextBrush}" />
        <Setter Property="FontStyle" Value="Italic" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="TextAlignment" Value="Left" />
        <Setter Property="Margin" Value="12,8,12,0" />
    </Style>

</ResourceDictionary>