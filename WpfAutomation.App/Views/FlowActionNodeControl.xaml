<UserControl x:Class="WpfAutomation.App.Views.FlowActionNodeControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:views="clr-namespace:WpfAutomation.App.Views"
             mc:Ignorable="d"
             ClipToBounds="False">
    <UserControl.Resources>
        <views:SelectionContainsNodeIdConverter x:Key="SelectionContainsNodeIdConverter" />
        <views:ActionNodeCredentialAssignedConverter x:Key="ActionNodeCredentialAssignedConverter" />

        <SolidColorBrush x:Key="Flow.ActionBorder" Color="#FFD5DDE8" />
        <SolidColorBrush x:Key="Flow.ActionFill" Color="#FFF7FBFF" />
        <SolidColorBrush x:Key="Flow.ActionText" Color="#FF2A394A" />
        <SolidColorBrush x:Key="Flow.ActionSubText" Color="#FF5D748A" />
        <SolidColorBrush x:Key="Flow.ActionAccent" Color="#FFBBD4EA" />

        <Style x:Key="FlowSelectionAwareBorderStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="{StaticResource Flow.ActionBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Style.Triggers>
                <DataTrigger Value="True">
                    <DataTrigger.Binding>
                        <MultiBinding Converter="{StaticResource SelectionContainsNodeIdConverter}">
                            <Binding Path="NodeId" />
                            <Binding Path="SelectedNodeIds" RelativeSource="{RelativeSource AncestorType=UserControl}" />
                        </MultiBinding>
                    </DataTrigger.Binding>
                    <Setter Property="BorderBrush" Value="#FF2F6FDC" />
                    <Setter Property="BorderThickness" Value="2" />
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="0" Color="#332F6FDC" Opacity="1" />
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Border Background="{StaticResource Flow.ActionFill}" Style="{StaticResource FlowSelectionAwareBorderStyle}">
        <Grid Height="50">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="48" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource Flow.ActionAccent}" BorderBrush="#FFABC5DE" BorderThickness="0,0,1,0">
                <TextBlock VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="#FF2D506F"
                           Text="{Binding ActionReference.IconKeyOrPath, TargetNullValue=+}" />
            </Border>

            <StackPanel Grid.Column="1" Margin="10,6,8,6" VerticalAlignment="Center">
                <TextBlock Text="{Binding DisplayLabel}" FontWeight="SemiBold" Foreground="{StaticResource Flow.ActionText}" TextTrimming="CharacterEllipsis" />
                <TextBlock Text="{Binding ActionReference.CategoryName}" FontSize="11" Foreground="{StaticResource Flow.ActionSubText}" TextTrimming="CharacterEllipsis" />
            </StackPanel>

            <TextBlock Grid.Column="1"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Top"
                       Margin="0,4,6,0"
                       FontFamily="Segoe MDL2 Assets"
                       FontSize="11"
                       Foreground="#FF2F6FDC"
                       Text="&#xE72E;"
                       Visibility="{Binding ActionParameters, Converter={StaticResource ActionNodeCredentialAssignedConverter}}" />

            <Border Width="16"
                    Height="16"
                    Grid.Column="0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Margin="-22,0,0,0"
                    CornerRadius="8"
                    Background="#FF177E43"
                    BorderBrush="#FFFFFFFF"
                    BorderThickness="1.2"
                    Visibility="Collapsed">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Value="True">
                                <DataTrigger.Binding>
                                    <MultiBinding Converter="{StaticResource SelectionContainsNodeIdConverter}">
                                        <Binding Path="NodeId" />
                                        <Binding Path="SuccessfulNodeIds" RelativeSource="{RelativeSource AncestorType=UserControl}" />
                                    </MultiBinding>
                                </DataTrigger.Binding>
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock FontSize="11"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="White"
                           Text="✔" />
            </Border>

            <Border Width="16"
                    Height="16"
                    Grid.Column="0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Margin="-22,0,0,0"
                    CornerRadius="8"
                    Background="#FFC62828"
                    BorderBrush="#FFFFFFFF"
                    BorderThickness="1.2"
                    Visibility="Collapsed">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Value="True">
                                <DataTrigger.Binding>
                                    <MultiBinding Converter="{StaticResource SelectionContainsNodeIdConverter}">
                                        <Binding Path="NodeId" />
                                        <Binding Path="FailedNodeIds" RelativeSource="{RelativeSource AncestorType=UserControl}" />
                                    </MultiBinding>
                                </DataTrigger.Binding>
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock FontSize="11"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="White"
                           Text="✖" />
            </Border>
        </Grid>
    </Border>
</UserControl>
