<UserControl x:Class="WpfAutomation.App.Views.StatusBarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:WpfAutomation.App.Models"
             xmlns:views="clr-namespace:WpfAutomation.App.Views"
             x:Name="Root"
             mc:Ignorable="d"
             d:DesignHeight="26"
             d:DesignWidth="920">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/WpfAutomation.App;component/Views/StatusBarStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <views:StatusBarIconGlyphConverter x:Key="StatusBarIconGlyphConverter" />

            <DataTemplate x:Key="StatusBarItemTemplate" DataType="{x:Type models:StatusBarItemModel}">
                <Button Style="{StaticResource StatusBarItemButtonStyle}"
                        Command="{Binding Command}"
                        CommandParameter="{Binding CommandParameter}"
                        IsEnabled="{Binding IsEnabled}"
                        ToolTip="{Binding ToolTip}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding IconGlyph, Converter={StaticResource StatusBarIconGlyphConverter}}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource StatusBarItemIconStyle}">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IconGlyph}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IconGlyph}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <TextBlock Text="{Binding Text}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource StatusBarItemTextStyle}">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Text}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Button>
            </DataTemplate>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Style="{StaticResource StatusBarRootBorderStyle}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ItemsControl Grid.Column="0"
                          ItemsSource="{Binding LeftItems, ElementName=Root}"
                          ItemTemplate="{StaticResource StatusBarItemTemplate}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Style="{StaticResource StatusBarStripPanelStyle}" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>

            <Border Grid.Column="1" />

            <ItemsControl Grid.Column="2"
                          ItemsSource="{Binding RightItems, ElementName=Root}"
                          ItemTemplate="{StaticResource StatusBarItemTemplate}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Style="{StaticResource StatusBarStripPanelStyle}" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </Grid>
    </Border>
</UserControl>