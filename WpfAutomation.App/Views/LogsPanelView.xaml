<UserControl x:Class="WpfAutomation.App.Views.LogsPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:WpfAutomation.App.Models"
             mc:Ignorable="d">
    <Border Margin="8" Padding="8" Background="#FFF7F9FC" BorderBrush="#FFD6E0EA" BorderThickness="1" CornerRadius="6">
        <ListBox x:Name="LogsListBox"
                 ItemsSource="{Binding Logs}"
                 BorderThickness="0"
                 Background="Transparent"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 PreviewMouseRightButtonDown="LogsListBox_OnPreviewMouseRightButtonDown">
            <ListBox.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Copy"
                              Click="CopyMenuItem_OnClick">
                        <MenuItem.Style>
                            <Style TargetType="MenuItem">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </MenuItem.Style>
                    </MenuItem>
                    <MenuItem Header="Copy All"
                              Click="CopyAllMenuItem_OnClick" />
                </ContextMenu>
            </ListBox.ContextMenu>
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type models:UiLogItem}">
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="72" />
                            <ColumnDefinition Width="60" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Margin="0,0,8,0"
                                   Foreground="#FF5A6E81"
                                   Text="{Binding TimestampUtc, StringFormat={}{0:HH:mm:ss}}" />
                        <TextBlock Grid.Column="1"
                                   Margin="0,0,8,0"
                                   FontWeight="SemiBold"
                                   Foreground="#FF23415A"
                                   Text="{Binding Level}" />
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{Binding Message}" TextWrapping="Wrap" />
                            <TextBlock Foreground="#FF5A6E81"
                                       Text="{Binding ScreenshotPath}"
                                       TextWrapping="Wrap">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <Trigger Property="Text" Value="">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </Trigger>
                                            <Trigger Property="Text" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Border>
</UserControl>
