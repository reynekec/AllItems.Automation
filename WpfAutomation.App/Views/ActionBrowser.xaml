<UserControl x:Class="WpfAutomation.App.Views.ActionBrowser"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:WpfAutomation.App.Models"
             x:Name="Root"
             mc:Ignorable="d"
             MinWidth="260"
             d:DesignHeight="560"
             d:DesignWidth="320">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/WpfAutomation.App;component/Views/ActionsSidebarStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <Style x:Key="ActionsSidebarTreeViewItemContainerStyle"
                   TargetType="TreeViewItem"
                   BasedOn="{StaticResource ActionsSidebarTreeViewItemBaseStyle}">
                <EventSetter Event="Loaded" Handler="CategoryTreeItem_OnLoaded" />
                <EventSetter Event="Expanded" Handler="CategoryTreeItem_OnExpanded" />
                <EventSetter Event="Collapsed" Handler="CategoryTreeItem_OnCollapsed" />
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Style="{StaticResource ActionsSidebarRootBorderStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Style="{StaticResource ActionsSidebarHeaderTextStyle}" Text="Actions" />

            <Border Grid.Row="1" Style="{StaticResource ActionsSidebarSearchContainerStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Path Grid.Column="0"
                          Margin="6,0,6,0"
                          Width="12"
                          Height="12"
                          Stretch="Uniform"
                          VerticalAlignment="Center"
                          Fill="{StaticResource ActionsSidebarSearchIconBrush}"
                          Data="F1 M 10.84,9.97L14.53,13.66L13.66,14.53L9.97,10.84C9.12,11.52 8.06,11.92 6.92,11.92C4.20,11.92 2.00,9.72 2.00,7.00C2.00,4.28 4.20,2.08 6.92,2.08C9.64,2.08 11.84,4.28 11.84,7.00C11.84,8.14 11.44,9.20 10.84,9.97z M 6.92,3.33C4.92,3.33 3.33,4.92 3.33,6.92C3.33,8.92 4.92,10.51 6.92,10.51C8.92,10.51 10.51,8.92 10.51,6.92C10.51,4.92 8.92,3.33 6.92,3.33z" />

                    <Grid Grid.Column="1">
                        <TextBox x:Name="SearchInput"
                                 Style="{StaticResource ActionsSidebarSearchBoxStyle}"
                                 Text="{Binding SearchText, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="Search actions"
                                   Foreground="{StaticResource ActionsSidebarSearchPlaceholderBrush}"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   Margin="2,0,0,0"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=SearchInput}" Value="">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Text, ElementName=SearchInput}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Grid>
            </Border>

            <Grid Grid.Row="2">
                <ScrollViewer x:Name="CategoryScrollViewer" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <TreeView x:Name="CategoryTree"
                              Style="{StaticResource ActionsSidebarTreeViewStyle}"
                              PreviewMouseWheel="CategoryTree_OnPreviewMouseWheel"
                              ItemsSource="{Binding FilteredCategoriesSource, ElementName=Root}">
                        <TreeView.Resources>
                            <HierarchicalDataTemplate x:Key="CategoryTreeTemplate"
                                                      DataType="{x:Type models:UiActionCategory}"
                                                      ItemsSource="{Binding Items}">
                                <TextBlock Style="{StaticResource ActionsSidebarCategoryHeaderTextStyle}"
                                           Text="{Binding CategoryName}"
                                           PreviewMouseLeftButtonUp="CategoryHeader_OnPreviewMouseLeftButtonUp" />
                            </HierarchicalDataTemplate>
                            <DataTemplate DataType="{x:Type models:UiActionItem}">
                                <Button Content="{Binding DisplayName}"
                                        Style="{StaticResource ActionsSidebarActionButtonStyle}"
                                        Click="ActionInvokeButton_OnClick"
                                        PreviewMouseLeftButtonDown="ActionInvokeButton_OnPreviewMouseLeftButtonDown"
                                        PreviewMouseLeftButtonUp="ActionInvokeButton_OnPreviewMouseLeftButtonUp"
                                        PreviewMouseMove="ActionInvokeButton_OnPreviewMouseMove" />
                            </DataTemplate>
                        </TreeView.Resources>
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem"
                                   BasedOn="{StaticResource ActionsSidebarTreeViewItemContainerStyle}" />
                        </TreeView.ItemContainerStyle>
                        <TreeView.ItemTemplate>
                            <StaticResource ResourceKey="CategoryTreeTemplate" />
                        </TreeView.ItemTemplate>
                    </TreeView>
                </ScrollViewer>

                <TextBlock Text="No matching actions found. Try a different keyword."
                           Visibility="Collapsed">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource ActionsSidebarEmptyStateStyle}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasItems, ElementName=CategoryTree}" Value="False">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </Grid>
    </Border>
</UserControl>