<Window x:Class="WpfAutomation.App.Docking.Controls.DockFloatingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Floating Panel"
        Height="320"
        Width="420"
        MinHeight="220"
        MinWidth="280"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="White">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="PanelTitle"
                   FontWeight="SemiBold"
                   FontSize="14"
                   Margin="0,0,0,8"
                   Text="Floating panel" />

        <Border Grid.Row="1"
                BorderThickness="1"
                BorderBrush="#CCD3DF"
                CornerRadius="4"
                Padding="10"
                Background="#F9FBFD">
            <TextBlock x:Name="PanelContent"
                       TextWrapping="Wrap"
                       Text="Floating panel content" />
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button x:Name="DragToDockButton"
                    Content="Drag to dock"
                    MinWidth="100"
                    Height="30"
                    Margin="0,0,8,0"
                    PreviewMouseLeftButtonDown="DragToDockButton_OnPreviewMouseLeftButtonDown"
                    PreviewMouseMove="DragToDockButton_OnPreviewMouseMove" />
            <Button Content="Close" MinWidth="84" Height="30" Click="CloseButton_OnClick" />
        </StackPanel>
    </Grid>
</Window>
