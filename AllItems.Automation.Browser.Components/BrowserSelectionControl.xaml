<UserControl x:Class="SelectorDemo.Wpf.BrowserSelectionControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="220"
             d:DesignWidth="340">
    <UserControl.Resources>
        <SolidColorBrush x:Key="PanelSurfaceBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#D6DEE8" />
        <SolidColorBrush x:Key="PanelMutedTextBrush" Color="#5B6677" />

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Background" Value="#0F6CBD" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#0F6CBD" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#0D5FA7" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#0B4F8A" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Padding="0"
            Margin="0,0,0,8"
            Background="{StaticResource PanelSurfaceBrush}"
            BorderBrush="{StaticResource PanelBorderBrush}"
            BorderThickness="1"
            CornerRadius="12"
            ClipToBounds="True">
        <TabControl>
            <!-- Selection Result Tab -->
            <TabItem Header="Selection Result" Padding="12,8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#5B6677"
                               Text="Status" />

                    <TextBlock x:Name="StatusTextBlock"
                               Grid.Row="1"
                               Margin="0,4,0,10"
                               Foreground="#1F2937"
                               TextWrapping="Wrap"
                               Text="No element selected." />

                    <TextBlock Grid.Row="2"
                               Margin="0,0,0,4"
                               FontWeight="SemiBold"
                               FontSize="13"
                               Foreground="#5B6677"
                               Text="CSS Selector" />

                    <Grid Grid.Row="3" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="CssSelectorTextBox"
                                 Grid.Column="0"
                                 IsReadOnly="True"
                                 Padding="8"
                                 TextWrapping="Wrap"
                                 Background="#F8FAFC"
                                 BorderBrush="{StaticResource PanelBorderBrush}"
                                 MinHeight="40" />
                        <Button Grid.Column="2"
                                Style="{StaticResource ActionButtonStyle}"
                                VerticalAlignment="Top"
                                Click="CopyCss_Click"
                                Content="Copy" />
                    </Grid>

                    <TextBlock Grid.Row="4"
                               Margin="0,0,0,4"
                               FontWeight="SemiBold"
                               FontSize="13"
                               Foreground="#5B6677"
                               Text="XPath Selector" />

                    <Grid Grid.Row="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="XPathSelectorTextBox"
                                 Grid.Column="0"
                                 IsReadOnly="True"
                                 Padding="8"
                                 TextWrapping="Wrap"
                                 Background="#F8FAFC"
                                 BorderBrush="{StaticResource PanelBorderBrush}"
                                 MinHeight="40" />
                        <Button Grid.Column="2"
                                Style="{StaticResource ActionButtonStyle}"
                                VerticalAlignment="Top"
                                Click="CopyXPath_Click"
                                Content="Copy" />
                    </Grid>
                </Grid>
            </TabItem>

            <!-- Element Browser Tab -->
            <TabItem Header="Element Browser" Padding="12,8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- HTML Source Section -->
                    <TextBlock FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#5B6677"
                               Text="HTML Source" />

                    <TextBox x:Name="HtmlSourceTextBox"
                             Grid.Row="1"
                             IsReadOnly="True"
                             Padding="8"
                             TextWrapping="Wrap"
                             Background="#F8FAFC"
                             BorderBrush="{StaticResource PanelBorderBrush}"
                             MinHeight="60"
                             Margin="0,4,0,10"
                             FontFamily="Consolas, Monaco, Courier New"
                             FontSize="11" />

                    <!-- Attributes Section -->
                    <TextBlock Grid.Row="2"
                               Margin="0,0,0,4"
                               FontWeight="SemiBold"
                               FontSize="13"
                               Foreground="#5B6677"
                               Text="Attributes" />

                    <TextBox x:Name="AttributesTextBox"
                             Grid.Row="3"
                             IsReadOnly="True"
                             Padding="8"
                             TextWrapping="Wrap"
                             Background="#F8FAFC"
                             BorderBrush="{StaticResource PanelBorderBrush}"
                             MinHeight="40"
                             Margin="0,0,0,10"
                             FontFamily="Consolas, Monaco, Courier New"
                             FontSize="11" />

                    <!-- Computed Styles Section -->
                    <TextBlock Grid.Row="4"
                               Margin="0,0,0,4"
                               FontWeight="SemiBold"
                               FontSize="13"
                               Foreground="#5B6677"
                               Text="Computed Styles" />

                    <TextBox x:Name="ComputedStylesTextBox"
                             Grid.Row="5"
                             IsReadOnly="True"
                             Padding="8"
                             TextWrapping="Wrap"
                             Background="#F8FAFC"
                             BorderBrush="{StaticResource PanelBorderBrush}"
                             MinHeight="40"
                             FontFamily="Consolas, Monaco, Courier New"
                             FontSize="11"
                             VerticalScrollBarVisibility="Auto" />
                </Grid>
            </TabItem>

            <!-- DOM Tree Tab -->
            <TabItem Header="DOM Tree" Padding="12,8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#5B6677"
                               Margin="0,0,0,8"
                               Text="Full DOM Hierarchy (selected element shown in bold blue)" />

                    <TreeView x:Name="DomTreeView"
                              Grid.Row="1"
                              Background="#F8FAFC"
                              BorderBrush="{StaticResource PanelBorderBrush}"
                              BorderThickness="1"
                              Padding="8"
                              FontFamily="Consolas, Monaco, Courier New"
                              FontSize="11" />
                </Grid>
            </TabItem>
        </TabControl>
    </Border>
</UserControl>
