<UserControl x:Class="SelectorDemo.Wpf.BrowserDebugControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="640"
             d:DesignWidth="340">
    <UserControl.Resources>
        <SolidColorBrush x:Key="PanelSurfaceBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#D6DEE8" />

        <Style x:Key="StatusTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{Binding StatusBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="DebugActionButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Background" Value="#EEF3FA" />
            <Setter Property="Foreground" Value="#1F2937" />
            <Setter Property="BorderBrush" Value="#CBD6E5" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#E0E9F6" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#D4E2F4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Padding="12"
            Background="{StaticResource PanelSurfaceBrush}"
            BorderBrush="{StaticResource PanelBorderBrush}"
            BorderThickness="1"
            CornerRadius="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock FontSize="15"
                       FontWeight="SemiBold"
                       Foreground="#1F2937"
                       Text="Debug Session" />

            <TextBlock x:Name="SessionStatusTextBlock"
                       Grid.Row="1"
                       Margin="0,6,0,10"
                       Foreground="#5B6677"
                       Text="Debug capture is idle." />

            <Grid Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="FilterTextBox"
                             Grid.Column="0"
                             Padding="6,4"
                             Background="#F8FAFC"
                             BorderBrush="{StaticResource PanelBorderBrush}"
                             TextChanged="FilterTextBox_TextChanged"
                             ToolTip="Filter by message or detail" />

                    <Button Grid.Column="2"
                            Style="{StaticResource DebugActionButtonStyle}"
                            Click="CopyButton_Click"
                            Content="Copy" />

                        <Button Grid.Column="4"
                            Style="{StaticResource DebugActionButtonStyle}"
                            Click="ClearButton_Click"
                            Content="Clear" />
                </Grid>

                    <TabControl x:Name="DebugTabs"
                            Grid.Row="1">
                    <TabItem Header="Console">
                        <DataGrid x:Name="ConsoleEntriesDataGrid"
                                  AutoGenerateColumns="False"
                                  CanUserSortColumns="True"
                                  IsReadOnly="True"
                                  MouseDoubleClick="ConsoleEntriesDataGrid_MouseDoubleClick"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  RowHeaderWidth="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Time" Binding="{Binding Timestamp}" Width="72" SortMemberPath="Timestamp" />
                                <DataGridTextColumn Header="Severity"
                                                    Binding="{Binding StatusText}"
                                                    Width="90"
                                                    SortMemberPath="StatusText"
                                                    ElementStyle="{StaticResource StatusTextStyle}" />
                                <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*" SortMemberPath="Message" />
                                <DataGridTextColumn Header="Detail" Binding="{Binding Detail}" Width="1.2*" SortMemberPath="Detail" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>

                    <TabItem Header="Network">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <WrapPanel Margin="0,0,0,8">
                                <RadioButton GroupName="NetworkTypeFilter"
                                             Margin="0,0,6,6"
                                             Padding="8,2"
                                             Content="All"
                                             Tag="All"
                                             Checked="NetworkTypeFilter_Checked"
                                             IsChecked="True" />
                                <RadioButton GroupName="NetworkTypeFilter"
                                             Margin="0,0,6,6"
                                             Padding="8,2"
                                             Content="Fetch/XHR"
                                             Tag="Fetch/XHR"
                                             Checked="NetworkTypeFilter_Checked" />
                                <RadioButton GroupName="NetworkTypeFilter"
                                             Margin="0,0,6,6"
                                             Padding="8,2"
                                             Content="Doc"
                                             Tag="Doc"
                                             Checked="NetworkTypeFilter_Checked" />
                                <RadioButton GroupName="NetworkTypeFilter"
                                             Margin="0,0,6,6"
                                             Padding="8,2"
                                             Content="CSS"
                                             Tag="CSS"
                                             Checked="NetworkTypeFilter_Checked" />
                                <RadioButton GroupName="NetworkTypeFilter"
                                             Margin="0,0,6,6"
                                             Padding="8,2"
                                             Content="JS"
                                             Tag="JS"
                                             Checked="NetworkTypeFilter_Checked" />
                                <RadioButton GroupName="NetworkTypeFilter"
                                             Margin="0,0,6,6"
                                             Padding="8,2"
                                             Content="Font"
                                             Tag="Font"
                                             Checked="NetworkTypeFilter_Checked" />
                                <RadioButton GroupName="NetworkTypeFilter"
                                             Margin="0,0,6,6"
                                             Padding="8,2"
                                             Content="Img"
                                             Tag="Img"
                                             Checked="NetworkTypeFilter_Checked" />
                                <RadioButton GroupName="NetworkTypeFilter"
                                             Margin="0,0,6,6"
                                             Padding="8,2"
                                             Content="Media"
                                             Tag="Media"
                                             Checked="NetworkTypeFilter_Checked" />
                                <RadioButton GroupName="NetworkTypeFilter"
                                             Margin="0,0,6,6"
                                             Padding="8,2"
                                             Content="Manifest"
                                             Tag="Manifest"
                                             Checked="NetworkTypeFilter_Checked" />
                                <RadioButton GroupName="NetworkTypeFilter"
                                             Margin="0,0,6,6"
                                             Padding="8,2"
                                             Content="Socket"
                                             Tag="Socket"
                                             Checked="NetworkTypeFilter_Checked" />
                                <RadioButton GroupName="NetworkTypeFilter"
                                             Margin="0,0,6,6"
                                             Padding="8,2"
                                             Content="Wasm"
                                             Tag="Wasm"
                                             Checked="NetworkTypeFilter_Checked" />
                                <RadioButton GroupName="NetworkTypeFilter"
                                             Margin="0,0,6,6"
                                             Padding="8,2"
                                             Content="Other"
                                             Tag="Other"
                                             Checked="NetworkTypeFilter_Checked" />
                            </WrapPanel>

                            <DataGrid x:Name="NetworkEntriesDataGrid"
                                      Grid.Row="1"
                                      AutoGenerateColumns="False"
                                      CanUserSortColumns="True"
                                      IsReadOnly="True"
                                      MouseDoubleClick="NetworkEntriesDataGrid_MouseDoubleClick"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      RowHeaderWidth="0">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Time" Binding="{Binding Timestamp}" Width="72" SortMemberPath="Timestamp" />
                                    <DataGridTextColumn Header="Type" Binding="{Binding NetworkType}" Width="90" SortMemberPath="NetworkType" />
                                    <DataGridTextColumn Header="Status"
                                                        Binding="{Binding StatusText}"
                                                        Width="80"
                                                        SortMemberPath="StatusText"
                                                        ElementStyle="{StaticResource StatusTextStyle}" />
                                    <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*" SortMemberPath="Message" />
                                    <DataGridTextColumn Header="Detail" Binding="{Binding Detail}" Width="1.2*" SortMemberPath="Detail" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Grid>
        </Grid>
    </Border>
</UserControl>