<Window x:Class="SelectorDemo.Wpf.BrowserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SelectorDemo.Wpf"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        Title="Browser Content" WindowStartupLocation="CenterScreen" WindowState="Maximized" Icon="pack://application:,,,/AllItems.Automation.Browser.Components;component/SelectorDemo.ico" Background="#F3F3F3">
    <Window.Resources>
        <ResourceDictionary Source="pack://application:,,,/AllItems.Automation.Browser.Components;component/Styles.xaml"/>
    </Window.Resources>
    
    <DockPanel>

        <!-- Toolbar -->
        <Border DockPanel.Dock="Top"
                Background="#0078D4"
                BorderBrush="#005A9E"
                BorderThickness="0,0,0,1"
                MinHeight="44"
                Padding="8,6">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="btnSelectElement" Padding="12,6" Style="{StaticResource ModernButtonStyle}" ToolTip="Select Element" Click="btnSelectElement_Click">
                    <Viewbox Width="16" Height="16">
                        <Path Fill="White" Data="M 0,0 L 0,12 L 3.5,9 L 6,14 L 8,13 L 5.5,8 L 9,8 Z" />
                    </Viewbox>
                </Button>
                <ToggleButton x:Name="btnToggleDebug"
                              Margin="8,0,0,0"
                              Padding="12,6"
                              Style="{StaticResource ModernToggleButtonStyle}"
                              ToolTip="Start debugging"
                              Checked="btnToggleDebug_Checked"
                              Unchecked="btnToggleDebug_Unchecked">
                    <Viewbox Width="16" Height="16">
                        <Canvas Width="16" Height="16">
                            <Path Fill="Black"
                                  Data="M8,0.8 L10.5,3.1 L13.8,3.4 L14.6,6.5 L16,9.4 L13.8,11.6 L13.4,14.8 L10.3,15.2 L8,16 L5.7,15.2 L2.6,14.8 L2.2,11.6 L0,9.4 L1.4,6.5 L2.2,3.4 L5.5,3.1 Z M8,4.7 A3.3,3.3 0 1 0 8,11.3 A3.3,3.3 0 1 0 8,4.7 Z" />
                            <Path x:Name="DebugButtonStateGlyph"
                                  Fill="Black"
                                  Data="M6,5 L11,8 L6,11 Z" />
                        </Canvas>
                    </Viewbox>
                </ToggleButton>
            </StackPanel>
        </Border>

        <Grid Margin="12" Background="White">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="300"/>
                <ColumnDefinition x:Name="SelectorSplitterColumn" Width="0"/>
                <ColumnDefinition x:Name="SelectorPanelColumn" Width="0"/>
                <ColumnDefinition x:Name="DebugSplitterColumn" Width="0"/>
                <ColumnDefinition x:Name="DebugPanelColumn" Width="0"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <wv2:WebView2 x:Name="BrowserView"
                          Grid.Row="0"
                          Grid.Column="0" />

            <GridSplitter x:Name="SelectorPanelSplitter"
                          Grid.Row="0"
                          Grid.Column="1"
                          Width="6"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="#E1E1E1"
                          ShowsPreview="True"
                          ResizeDirection="Columns"
                          ResizeBehavior="PreviousAndNext"
                          Visibility="Collapsed" />

            <local:BrowserSelectionControl x:Name="SelectionPanel"
                                           Grid.Row="0"
                                           Grid.Column="2"
                                           Visibility="Collapsed" />

            <GridSplitter x:Name="DebugPanelSplitter"
                          Grid.Row="0"
                          Grid.Column="3"
                          Width="6"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="#E1E1E1"
                          ShowsPreview="True"
                          ResizeDirection="Columns"
                          ResizeBehavior="PreviousAndNext"
                          Visibility="Collapsed" />

            <local:BrowserDebugControl x:Name="DebugPanel"
                                       Grid.Row="0"
                                       Grid.Column="4"
                                       Visibility="Collapsed" />

            <Border Grid.Row="0"
                    Grid.Column="5"
                    Margin="2,0,0,0"
                    Background="#F9F9F9"
                    BorderBrush="#D0D0D0"
                    BorderThickness="1,0,0,0">
                <StackPanel Orientation="Vertical"
                            VerticalAlignment="Top"
                            Margin="0,12,0,0">
                    <ToggleButton x:Name="SelectorDockTab"
                                  Margin="0,0,0,4"
                                  HorizontalAlignment="Right"
                                  Padding="4,10"
                                  Style="{StaticResource ModernToggleButtonStyle}"
                                  ToolTip="Toggle Selector panel"
                                  Checked="SelectorDockTab_Checked"
                                  Unchecked="SelectorDockTab_Unchecked">
                        <TextBlock Text="Selector"
                                   FontWeight="SemiBold"
                                   FontSize="11">
                            <TextBlock.LayoutTransform>
                                <RotateTransform Angle="-90" />
                            </TextBlock.LayoutTransform>
                        </TextBlock>
                    </ToggleButton>

                    <ToggleButton x:Name="DebugDockTab"
                                  HorizontalAlignment="Right"
                                  Padding="4,10"
                                  Style="{StaticResource ModernToggleButtonStyle}"
                                  ToolTip="Toggle Debug panel"
                                  Checked="DebugDockTab_Checked"
                                  Unchecked="DebugDockTab_Unchecked">
                        <TextBlock Text="Debug"
                                   FontWeight="SemiBold"
                                   FontSize="11">
                            <TextBlock.LayoutTransform>
                                <RotateTransform Angle="-90" />
                            </TextBlock.LayoutTransform>
                        </TextBlock>
                    </ToggleButton>
                </StackPanel>
            </Border>

            <TextBlock Grid.Row="2"
                       Grid.Column="0"
                       Grid.ColumnSpan="6"
                       Margin="0,6,0,4"
                       FontWeight="SemiBold"
                       Foreground="#333333"
                       Text="Status" />
            <TextBox x:Name="StatusTextBox"
                     Grid.Row="3"
                     Grid.Column="0"
                     Grid.ColumnSpan="6"
                     IsReadOnly="True"
                     Style="{StaticResource ModernTextBoxStyle}"
                     Text="Ready. Navigate to a page and click Start Selection (In-App)." />
        </Grid>
    </DockPanel>
</Window>
